{
  "name": "@b-kamphorst/docusaurus-glossary-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "build": "tsc -b packages/plugin packages/theme",
    "clean": "rimraf ./packages/**/dist ./packages/**/tsconfig.tsbuildinfo ./example/.docusaurus",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "validate": "npm run typecheck && npm run lint",
    "example:build": "cd example && npm run build",
    "example:start": "cd example && npm start"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "^9.39.3",
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.36.0",
    "unified": "^11.0.5"
  }
}
