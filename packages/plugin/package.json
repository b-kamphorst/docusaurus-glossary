{
  "name": "@b-kamphorst/docusaurus-plugin-glossary",
  "version": "0.1.0",
  "description": "Docusaurus plugin to generate a glossary from markdown files ('terms'). All references to terms are transformed into tooltips that display short descriptions on hover.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./remark": {
      "import": "./dist/remark/index.js",
      "require": "./dist/remark/index.js",
      "types": "./dist/remark/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "docusaurus",
    "glossary"
  ],
  "author": "Bart Kamphorst",
  "license": "MIT",
  "dependencies": {
    "front-matter": "^4.0.2",
    "slugify": "^1.6.6",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
