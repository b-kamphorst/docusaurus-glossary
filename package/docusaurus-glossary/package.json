{
  "name": "@b-kamphorst/docusaurus-glossary",
  "version": "0.2.0",
  "description": "Docusaurus plugin and theme to generate and render a glossary from markdown files ('terms'). All references to terms are transformed into tooltips that display short descriptions on hover.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "docusaurus",
    "definitions",
    "dictionary",
    "glossary",
    "terminology",
    "terms"
  ],
  "author": "Bart Kamphorst",
  "license": "MIT",
  "dependencies": {
    "abstract-syntax-tree": "^2.22.0",
    "front-matter": "^4.0.2",
    "react-tooltip": "^5.30.0",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "@docusaurus/core": "^3.9.0",
    "@docusaurus/theme-classic": "^3.9.0",
    "@docusaurus/types": "^3.9.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
